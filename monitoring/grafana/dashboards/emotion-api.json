{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Requests Per Second",
      "description": "How many requests is the API handling right now? Spike = traffic surge. Drop to zero = API might be down.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(request_count_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} ({{status}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Prediction Latency (p50 vs p99)",
      "description": "p50 = half of requests are faster than this. p99 = 99% are faster. Big gap between p50 and p99 means some requests are much slower — investigate those.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(request_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 (median)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(request_latency_seconds_bucket[5m]))",
          "legendFormat": "p99 (worst 1%)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate %",
      "description": "Percentage of requests that return 500 errors. Green = good (< 1%). Yellow = warning (1-5%). Red = something is broken (> 5%).",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(rate(request_count_total{status=\"500\"}[5m])) / sum(rate(request_count_total[5m]))) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "title": "Predictions by Emotion",
      "description": "Distribution of predicted emotions. If one emotion dominates (>80%), the model might be broken or biased. Normal = roughly balanced.",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prediction_count_total",
          "legendFormat": "{{emotion}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "title": "Average Confidence Score",
      "description": "How confident is the model? Above 0.7 = healthy. Dropping below 0.5 = model is struggling, might need retraining. This is your ML early warning system.",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(prediction_confidence_sum[5m]) / rate(prediction_confidence_count[5m])",
          "legendFormat": "Avg Confidence",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "title": "Total Requests Today",
      "description": "Total number of requests since the counter was last reset (typically since container restart). Shows overall API usage.",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(request_count_total)",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "emotion-detection",
    "ml-monitoring"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Emotion Detection API",
  "uid": "emotion-api-dashboard",
  "version": 1
}